# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./server/db/ops.db

# Twilio (SMS notifications)
